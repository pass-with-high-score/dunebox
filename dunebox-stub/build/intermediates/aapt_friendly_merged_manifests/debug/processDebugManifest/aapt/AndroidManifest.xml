    package="app.pwhs.dunebox.stub" >

    <uses-sdk android:minSdkVersion="26" />

    <!--
        DuneBox Stub Components
        ========================
        These are placeholder components that DuneBox uses to "trick" the Android
        framework into launching virtual app components. The framework requires all
        components to be declared in the manifest — so we pre-declare a pool of stubs.

        MVP: All stubs run in the MAIN process for simplicity.
        Future: Multi-process support via :p0, :p1, :p2
    -->
    <application>

        <!-- ==================== STUB ACTIVITIES: Standard ==================== -->
        <activity
            android:name="app.pwhs.dunebox.stub.StubActivity$P0$S0"
            android:configChanges="mcc|mnc|locale|touchscreen|keyboard|keyboardHidden|navigation|orientation|screenLayout|uiMode|screenSize|smallestScreenSize|fontScale|layoutDirection|density"
            android:exported="false"
            android:taskAffinity="app.pwhs.dunebox.vt.s0" />
